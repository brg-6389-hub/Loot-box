# Comentario PT-PT: configuracao base para correr a aplicacao apenas em ambiente local.

# Mantem a API limitada a loopback para nao ficar acessivel na rede local.
API_HOST=127.0.0.1
API_PORT=8787

# Origem autorizada do frontend local para CORS e callbacks.
CLIENT_URL=http://127.0.0.1:4173
VITE_API_URL=http://127.0.0.1:8787

# Substituir por um segredo forte se a aplicacao for usada fora de testes locais.
JWT_SECRET=trocar_por_um_segredo_local_forte

# Integracoes opcionais.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Firebase opcional para autenticacao remota.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
